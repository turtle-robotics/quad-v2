<?xml version="1.0"?>
<?xml-model href="https://raw.githubusercontent.com/ros/urdfdom/master/xsd/urdf.xsd"?>
<robot name="QUAD V2">

  <!-- Kinematic Properties (Joints) -->
  <joint name="world" type="fixed">
    <parent link="world" />
    <child link="body" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  <joint name="shoulder_1" type="revolute">
    <parent link="body" />
    <child link="upper_1" />
    <origin rpy="0 0 0" xyz="0.03591925 0.03591925 0" /> <!-- TODO: Update origin -->
    <axis xyz="0 0 1" />
  </joint>
  <joint name="upper_1" type="revolute">
    <parent link="upper_1" />
    <child link="lower_1" />
    <origin rpy="0 0 0" xyz="0.047 0 0" />
    <axis xyz="0 0 1" />
  </joint>
  <joint name="lower_1" type="revolute">
    <parent link="lower_1" />
    <child link="foot_1" />
    <origin rpy="0 0 0" xyz="0.192 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Inertial Properties (Links) -->
  <link name="world" />
  <link name="body">
    <inertial>
      <mass value="15.0" />
      <origin rpy="0 0 0" xyz="0 0 0" />
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0" />
    </inertial>
  </link>
  <link name="upper_1">
    <inertial>
      <mass value="0.0" />
      <origin rpy="0 0 0" xyz="0 0 0" />
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0" />
    </inertial>
  </link>
  <link name="lower_1">
    <inertial>
      <mass value="0.0" />
      <origin rpy="0 0 0" xyz="0 0 0" />
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0" />
    </inertial>
  </link>
  <link name="foot_1" />
</robot>