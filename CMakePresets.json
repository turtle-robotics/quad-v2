{
  "version": 4,
  "configurePresets": [
    {
      "name": "rpi",
      "displayName": "Cross Compile for Raspberry Pi",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/toolchain-aarch64.cmake"
      }
    },
    {
      "name": "local",
      "displayName": "Compile for local machine",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}